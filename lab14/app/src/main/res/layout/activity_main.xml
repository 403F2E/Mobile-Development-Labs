<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <!-- 403f2e has initialised the main container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <!-- 403f2e has created the name input field -->
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nom utilisateur" />
        <!-- 403f2e has created the language selection spinner -->
        <Spinner
            android:id="@+id/spLang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thème sombre" />
            <!-- 403f2e has created the dark theme switch -->
            <Switch
                android:id="@+id/swDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
        <!-- 403f2e has created the secure token input field -->
        <EditText
            android:id="@+id/etToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Token (stockage chiffré uniquement)"
            android:inputType="textPassword" />
        <!-- 403f2e has created the save preferences button -->
        <Button
            android:id="@+id/btnSavePrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sauvegarder prefs" />
        <!-- 403f2e has created the load preferences button -->
        <Button
            android:id="@+id/btnLoadPrefs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Charger prefs" />
        <!-- 403f2e has created the save JSON button -->
        <Button
            android:id="@+id/btnSaveJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sauvegarder fichier JSON" />
        <!-- 403f2e has created the load JSON button -->
        <Button
            android:id="@+id/btnLoadJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Charger fichier JSON" />
        <!-- 403f2e has created the clear all button -->
        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Effacer" />
        <!-- 403f2e has created the result display text view -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
